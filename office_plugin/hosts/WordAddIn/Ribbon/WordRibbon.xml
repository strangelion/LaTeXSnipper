<?xml version="1.0" encoding="utf-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="LaTeXSnipperTab" label="{RibbonTab}" keytip="LS">
        <group id="LaTeXSnipperFormulaGroup" label="{FormulaGroup}">
          <button id="InsertInlineButton"
                  label="{InsertInlineButton}"
                  supertip="{InsertInlineTip}"
                  keytip="I"
                  size="large"
                  imageMso="EquationProfessional"
                  onAction="OnInsertInline" />
          <button id="InsertDisplayButton"
                  label="{InsertDisplayButton}"
                  supertip="{InsertDisplayTip}"
                  keytip="D"
                  size="large"
                  imageMso="EquationInsertGallery"
                  onAction="OnInsertDisplay" />
          <button id="InsertNumberedButton"
                  label="{InsertNumberedButton}"
                  supertip="{InsertNumberedTip}"
                  keytip="N"
                  size="large"
                  imageMso="Numbering"
                  onAction="OnInsertNumbered" />
          <button id="ScreenshotOcrButton"
                  label="{ScreenshotOcrButton}"
                  supertip="{ScreenshotOcrTip}"
                  keytip="O"
                  size="large"
                  imageMso="ScreenshotInsertGallery"
                  onAction="OnScreenshotOcr" />
        </group>
        <group id="LaTeXSnipperEditGroup" label="{EditGroup}">
          <button id="LoadSelectedButton"
                  label="{LoadSelectedButton}"
                  supertip="{LoadSelectedTip}"
                  keytip="L"
                  size="large"
                  imageMso="ReviewDisplayForReview"
                  onAction="OnLoadSelected" />
          <button id="DeleteSelectedButton"
                  label="{DeleteSelectedButton}"
                  supertip="{DeleteSelectedTip}"
                  keytip="X"
                  size="large"
                  imageMso="Delete"
                  onAction="OnDeleteSelected" />
        </group>
        <group id="LaTeXSnipperToolsGroup" label="{ToolsGroup}">
          <button id="ShowTaskPaneButton" label="{ShowTaskPaneButton}" supertip="{ShowTaskPaneTip}" keytip="P" size="large" imageMso="ReviewingPane" onAction="OnShowTaskPane" />
          <button id="SettingsButton" label="{SettingsButton}" supertip="{SettingsTip}" keytip="S" size="large" imageMso="AdvancedFileProperties" onAction="OnSettings" />
          <button id="HelpButton" label="{HelpButton}" supertip="{HelpTip}" keytip="H" size="large" imageMso="Help" onAction="OnHelp" />
        </group>
      </tab>
      <tab id="LaTeXSnipperConversionTab" label="{ConversionTab}">
        <group id="LaTeXSnipperConversionSelectedGroup" label="{SelectedScopeGroup}">
          <button id="SelectedToOleButton" label="{ToOleButton}" supertip="{ToOleSelectedTip}" size="large" imageMso="ObjectEdit" onAction="OnConvertSelectedToOle" />
          <button id="SelectedToOmmlButton" label="{ToOmmlButton}" supertip="{ToOmmlSelectedTip}" size="large" imageMso="EquationProfessional" onAction="OnConvertSelectedToOmml" />
        </group>
        <group id="LaTeXSnipperConversionAllGroup" label="{DocumentScopeGroup}">
          <button id="AllToOleButton" label="{AllToOleButton}" supertip="{AllToOleTip}" size="large" imageMso="ObjectEdit" onAction="OnConvertAllToOle" />
          <button id="AllToOmmlButton" label="{AllToOmmlButton}" supertip="{AllToOmmlTip}" size="large" imageMso="EquationInsertGallery" onAction="OnConvertAllToOmml" />
        </group>
      </tab>
      <tab id="LaTeXSnipperReferenceTab" label="{ReferenceTab}">
        <group id="LaTeXSnipperReferenceGroup" label="{ReferenceGroup}">
          <button id="InsertReferenceButton" label="{InsertReferenceButton}" supertip="{InsertReferenceTip}" size="large" imageMso="CrossReferenceInsert" onAction="OnInsertReference" />
        </group>
      </tab>
      <tab id="LaTeXSnipperNumberingTab" label="{NumberingTab}">
        <group id="LaTeXSnipperNumberingGroup" label="{NumberingGroup}">
          <button id="AutoNumberButton"
                  label="{AutoNumberButton}"
                  supertip="{AutoNumberTip}"
                  keytip="A"
                  size="large"
                  imageMso="NumberingRestart"
                  onAction="OnAutoNumberSelected" />
          <button id="RenumberButton"
                  label="{RenumberButton}"
                  supertip="{RenumberTip}"
                  keytip="R"
                  size="large"
                  imageMso="RecurrenceEdit"
                  onAction="OnRenumberAll" />
        </group>
        <group id="LaTeXSnipperBoundaryGroup" label="{BoundaryGroup}">
          <button id="InsertChapterBoundaryButton" label="{InsertChapterBoundaryButton}" supertip="{InsertChapterBoundaryTip}" size="large" imageMso="OutlineNumbering" onAction="OnInsertChapterBoundary" />
          <button id="InsertSectionBoundaryButton" label="{InsertSectionBoundaryButton}" supertip="{InsertSectionBoundaryTip}" size="large" imageMso="BreaksGallery" onAction="OnInsertSectionBoundary" />
        </group>
      </tab>
      <tab id="LaTeXSnipperFormattingTab" label="{FormattingTab}">
        <group id="LaTeXSnipperFormattingGroup" label="{FormattingGroup}">
          <button id="FormatSelectedButton" label="{FormatSelectedButton}" supertip="{FormatSelectedTip}" size="large" imageMso="FormatPainter" onAction="OnFormatSelected" />
          <button id="FormatAllButton" label="{FormatAllButton}" supertip="{FormatAllTip}" size="large" imageMso="FontDialog" onAction="OnFormatAll" />
          <button id="FormattingSettingsButton" label="{SettingsButton}" supertip="{FormattingSettingsTip}" size="large" imageMso="FontColorPicker" onAction="OnSettings" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
