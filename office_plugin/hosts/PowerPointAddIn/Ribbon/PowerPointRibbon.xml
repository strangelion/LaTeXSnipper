<?xml version="1.0" encoding="utf-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
  <ribbon>
    <tabs>
      <tab id="LaTeXSnipperPowerPointTab" label="{RibbonTab}" keytip="LS">
        <group id="LaTeXSnipperPowerPointFormulaGroup" label="{FormulaGroup}">
          <button id="PowerPointInsertFormulaButton"
                  label="{InsertFormulaButton}"
                  supertip="{InsertFormulaTip}"
                  keytip="F"
                  size="large"
                  imageMso="EquationProfessional"
                  onAction="OnInsertFormula" />
          <button id="PowerPointScreenshotOcrButton"
                  label="{ScreenshotOcrButton}"
                  supertip="{ScreenshotOcrTip}"
                  keytip="O"
                  size="large"
                  imageMso="ScreenshotInsertGallery"
                  onAction="OnScreenshotOcr" />
        </group>
        <group id="LaTeXSnipperPowerPointEditGroup" label="{EditGroup}">
          <button id="PowerPointLoadSelectedButton"
                  label="{LoadSelectedButton}"
                  supertip="{LoadSelectedTip}"
                  keytip="L"
                  size="large"
                  imageMso="ReviewDisplayForReview"
                  onAction="OnLoadSelected" />
          <button id="PowerPointDeleteSelectedButton"
                  label="{DeleteSelectedButton}"
                  supertip="{DeleteSelectedTip}"
                  keytip="X"
                  size="large"
                  imageMso="Delete"
                  onAction="OnDeleteSelected" />
        </group>
        <group id="LaTeXSnipperPowerPointConversionGroup" label="{ConversionGroup}">
          <button id="PowerPointConvertSelectedToOle" label="{ToOleButton}" supertip="{ToOleTip}" size="large" imageMso="ObjectEditDialog" onAction="OnConvertSelectedToOle" />
          <button id="PowerPointConvertSelectedToPng" label="{ToPngButton}" supertip="{ToPngTip}" size="large" imageMso="PictureInsertFromFile" onAction="OnConvertSelectedToPng" />
        </group>
        <group id="LaTeXSnipperPowerPointFormattingGroup" label="{FormattingGroup}">
          <button id="PowerPointFormatSelectedButton" label="{FormatSelectedButton}" supertip="{FormatSelectedTip}" size="large" imageMso="FormatPainter" onAction="OnFormatSelected" />
          <button id="PowerPointFormatAllButton" label="{FormatAllButton}" supertip="{FormatAllTip}" size="large" imageMso="FontDialog" onAction="OnFormatAll" />
        </group>
        <group id="LaTeXSnipperPowerPointToolsGroup" label="{ToolsGroup}">
          <button id="PowerPointShowTaskPaneButton"
                  label="{ShowTaskPaneButton}"
                  supertip="{ShowTaskPaneTip}"
                  keytip="P"
                  size="large"
                  imageMso="ReviewingPane"
                  onAction="OnShowTaskPane" />
          <button id="PowerPointSettingsButton"
                  label="{SettingsButton}"
                  supertip="{SettingsTip}"
                  keytip="S"
                  size="large"
                  imageMso="AdvancedFileProperties"
                  onAction="OnSettings" />
          <button id="PowerPointHelpButton"
                  label="{HelpButton}"
                  supertip="{HelpTip}"
                  keytip="H"
                  size="large"
                  imageMso="Help"
                  onAction="OnHelp" />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
